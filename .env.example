# Environment configuration template.
# Copy this file to '.env' in the same folder and fill in your actual values.
# IMPORTANT: Never commit the '.env' file itself to Git repositories.

# --- Application Setup ---
ENVIRONMENT=local
DEBUG=true

# --- Database Setup ---
# Default connection string for local native PostgreSQL installation.
# Format: postgresql+asyncpg://<username>:<password>@<host>:<port>/<database_name>
DATABASE_URL=postgresql+asyncpg://postgres:postgres_pass@localhost:5432/vendor_dd

# --- Security / JWT Auth ---
# Run 'openssl rand -hex 32' in terminal to generate a secure secret key.
JWT_SECRET_KEY=generate_a_random_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Default Seed Admin (Created on startup) ---
SEED_ADMIN_EMAIL=admin@vendordd.internal-app.com
SEED_ADMIN_PASSWORD=change_this_admin_password_123!

# --- File Upload Limits ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=25

# --- OpenAI API Key ---
# Required for Milestones 2-5 (embeddings, document classification, agent prompts)
OPENAI_API_KEY=sk-proj-your-active-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
